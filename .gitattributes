* text=auto eol=lf

# Keep shell scripts LF for Unix execution.
*.sh text eol=lf

# Windows command scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.pdf binary
